commit_msg=$(cat "$1")
pattern="^(feat|fix|docs|style|refactor|perf|test|chore|revert|build|ci)(\(.+\))?: .+"
if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Commit message inválido. Use: tipo(escopo opcional): descrição"
  echo "   Exemplos: feat: add login, fix: corrige bug"
  exit 1
fi
